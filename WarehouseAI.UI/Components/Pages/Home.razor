@page "/"
@page "/{sessionId?}"

@inject WarehouseAI.Core.ChatSessionService ChatSessionService
@inject NavigationManager NavigationManager

<h3>Warehouse AI Assistant</h3>

<div class="d-flex mb-3 align-items-center">
    <button @onclick="CreateNewSession" class="btn btn-primary me-2">New</button>

    <select @bind="SelectedSessionId" class="form-select">
        <option value="">Select a session...</option>
        @foreach (var sessionId in SessionIds)
        {
            <option value="@sessionId">@sessionId</option>
        }
    </select>
</div>

@if (!string.IsNullOrEmpty(SelectedSessionId))
{
    <div class="sticky-top bg-white py-2 mb-3 border-bottom">
        <div class="input-group">
            <input @bind="UserInput" @bind:event="oninput" @onkeyup="HandleKeyPress" placeholder="Enter your query..." class="form-control" />
            <button @onclick="SendMessage" class="btn btn-primary">Send</button>
        </div>
    </div>

    <div class="chat-history p-3 border rounded bg-light">
        @foreach (var entry in ChatHistory)
        {
            <div class="mb-3">
                <div class="alert alert-primary">
                    <div><strong>User:</strong></div>
                    <div class="message-content">@entry.User</div>
                    <div class="timestamp text-end">@entry.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</div>
                </div>
                <div class="alert alert-secondary">
                    <div><strong>Assistant:</strong></div>
                    <div class="message-content">@entry.Assistant</div>
                    <div class="timestamp text-end">@entry.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</div>
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter]
    public string sessionId { get; set; }

    private List<Guid> SessionIds = new();
    private string _selectedSessionId;

    private string SelectedSessionId
    {
        get => _selectedSessionId;
        set
        {
            if (_selectedSessionId != value)
            {
                _selectedSessionId = value;
                LoadSessionById(_selectedSessionId);
            }
        }
    }

    private string UserInput = "";
    private List<(string User, string Assistant, DateTime Timestamp)> ChatHistory = new();

    protected override void OnInitialized()
    {
        LoadSessionIds();
        if (!string.IsNullOrEmpty(sessionId))
        {
            SelectedSessionId = sessionId;
        }
    }

    private void LoadSessionIds()
    {
        SessionIds = ChatSessionService.GetAllSessionIds();
    }

    private void LoadSessionById(string sessionId)
    {
        if (!string.IsNullOrEmpty(sessionId) && Guid.TryParse(sessionId, out var guid))
        {
            ChatHistory = ChatSessionService.GetChatHistoryById(guid).Select(entry => (entry.User, entry.Assistant, entry.Timestamp)).ToList();

            if (sessionId != this.sessionId)
            {
                NavigationManager.NavigateTo($"/{sessionId}", true);
            }
        }
    }

    private async Task SendMessage()
    {
        var assistantResponse = await ChatSessionService.SendMessageAsync(Guid.Parse(SelectedSessionId), UserInput);
        ChatHistory.Add((UserInput, assistantResponse, DateTime.UtcNow));

        UserInput = "";
    }

    private void CreateNewSession()
    {
        var sessionId = ChatSessionService.StartNewSession();
        SessionIds.Add(sessionId); // Append the new session ID to the list
        SelectedSessionId = sessionId.ToString();
        LoadSessionById(SelectedSessionId);
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SendMessage();
        }
    }
}

<style>
    .chat-history {
        overflow-y: auto;
        max-height: 70vh;
    }

    .message-content {
        white-space: pre-wrap;
        margin-top: 5px;
    }

    .timestamp {
        font-size: 0.8em;
        color: #888;
    }
</style>